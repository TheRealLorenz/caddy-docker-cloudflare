# FileName=caddy-pod
[Pod]
PodName=caddy
PublishPort=26080:80
PublishPort=26443:443
Network=caddy-net.network

[Install]
WantedBy=default.target

---

# FileName=caddy
[Container]
Image=ghcr.io/thereallorenz/caddy-cloudflare-ddns:0.3.1
Pod=caddy-pod.pod
Volume=caddy-data.volume:/data
Volume=%h/containers/caddy-cloudflare-ddns/conf:/etc/caddy
Secret=cf_api_token

[Service]
Restart=always

---

# FileName=caddy-net
[Network]
NetworkName=caddy

---

# FileName=caddy-data
[Volume]
